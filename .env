# API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your_secret_key_here_change_this_in_production

# Database Configuration (if using)
